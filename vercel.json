{
  "rewrites": [
    { "source": "/auth",       "destination": "/auth.html" },
    { "source": "/dashboard",  "destination": "/dashboard-customer.html" },
    { "source": "/admin",      "destination": "/dashboard-admin.html" },
    { "source": "/filter-ig",  "destination": "/filter-ig.html" },
    {
      "source": "/:slug((?!index|auth|dashboard|dashboard-admin|dashboard-customer|filter-ig|undangan|templates|images|css|js|vercel)([a-zA-Z0-9_-]+))",
      "destination": "/undangan.html?slug=:slug"
    }
  ]
}
